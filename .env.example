# ============================================================
# Template d'environnement TikTok_App (racine)
# Copier en `.env` et remplir avec les VRAIES valeurs (jamais committer).
# Genere les secrets fortement aleatoires :
#   openssl rand -base64 48        (Linux/macOS)
#   [Convert]::ToBase64String((1..36 | % { Get-Random -Max 256 } | %{ [byte]$_ }))   (PowerShell)
# ============================================================

# === Server ===
PORT=8081

# === Database (PostgreSQL local via docker-compose) ===
POSTGRES_PASSWORD=change-me

# === Admin bootstrap ===
APP_ADMIN_EMAIL=admin@tiktokapp.local
APP_ADMIN_PASSWORD=change-me-strong-password
APP_ADMIN_NAME=Video Ops Admin
APP_BOOTSTRAP_ADMIN_ON_STARTUP=true

# === JWT / cookies admin ===
# 64 chars base64 minimum
APP_JWT_SECRET=change-me-64-chars-base64
APP_ACCESS_MINUTES=30
APP_REFRESH_DAYS=14
APP_REFRESH_COOKIE_NAME=tiktok_app_admin_refresh
# false en dev (HTTP local), true en prod (HTTPS only)
APP_SECURE_COOKIES=false
APP_FRONTEND_BASE_URL=http://localhost:5174
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# === n8n encryption key ===
# Genere via : openssl rand -base64 32
N8N_ENCRYPTION_KEY=change-me-base64-32

# === Video ops -> n8n ===
APP_VIDEO_OPS_INTERNAL_API_SECRET=change-me
APP_VIDEO_OPS_WORKFLOW_CALLBACK_SECRET=change-me-legacy
APP_VIDEO_OPS_WORKFLOW_CALLBACK_HMAC_SECRET=change-me-strong-hmac
APP_VIDEO_OPS_WORKFLOW_CALLBACK_MAX_SKEW_SECONDS=300
# A passer false des que la migration HMAC est complete cote n8n
APP_VIDEO_OPS_ALLOW_LEGACY_WORKFLOW_CALLBACK_SECRET=true

# === Chiffrement applicatif des tokens TikTok stockes en BDD ===
# Genere via : openssl rand -base64 32
APP_VIDEO_OPS_TOKEN_ENCRYPTION_KEY=change-me-base64-32

# === TikTok OAuth ===
APP_VIDEO_OPS_TIKTOK_CLIENT_KEY=
APP_VIDEO_OPS_TIKTOK_CLIENT_SECRET=
APP_VIDEO_OPS_TIKTOK_REDIRECT_URI=https://your-public-host/tiktok-callback
APP_VIDEO_OPS_TIKTOK_OAUTH_SCOPES=user.info.basic,video.publish,video.upload
APP_VIDEO_OPS_ALLOWED_UPLOAD_HOSTS=open-upload.tiktokapis.com,open-upload-sg.tiktokapis.com,open.tiktokapis.com,business-api.tiktok.com
APP_VIDEO_OPS_RENDER_VIDEO_BASE_URL=http://render-video:8090

# === RenderVideo / Remotion ===
# URL retournee dans shotstack_url pendant la migration.
# Pour publier reellement sur TikTok, elle doit etre HTTPS et le host doit etre ajoute
# dans APP_VIDEO_OPS_ALLOWED_SHOTSTACK_HOSTS.
APP_RENDER_VIDEO_PUBLIC_BASE_URL=http://localhost:8090

# === Tiers (Groq, Pexels, Shotstack) ===
GROQ_API_KEY=
PEXELS_API_KEY=
SHOTSTACK_API_KEY=

# === ngrok (tunnel local optionnel) ===
NGROK_AUTHTOKEN=

# === Alerting Slack ===
APP_ALERTING_ENABLED=true
APP_ALERTING_SLACK_WEBHOOK_URL=
APP_ALERTING_COOLDOWN_SECONDS=300
APP_ALERTING_RATE_LIMIT_MAX_ALERTS=10
APP_ALERTING_RATE_LIMIT_WINDOW_SECONDS=600
APP_ALERTING_STUCK_RUN_THRESHOLD_SECONDS=600
APP_ALERTING_STUCK_RUN_CHECK_INTERVAL_MS=120000

# === n8n local ===
N8N_BASE_URL=http://localhost:5678
APP_VIDEO_OPS_N8N_READ_TIMEOUT_MS=600000
# Shotstack legacy:
APP_VIDEO_OPS_N8N_RENDER_PATH=/webhook/render-template-video
# Remotion migration:
# APP_VIDEO_OPS_N8N_RENDER_PATH=/webhook/render-template-video-remotion
# Cle n8n Public API (Settings -> API dans n8n UI). Necessaire pour
# Backend/tools/patch-n8n-idempotency.ps1 et autres scripts d'admin n8n.
# Ne JAMAIS commiter en clair.
N8N_API_KEY=
