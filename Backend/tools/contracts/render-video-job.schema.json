{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiktok-app.local/contracts/render-video-job.schema.json",
  "title": "Render Video Job",
  "description": "Versioned render contract for Shotstack/Remotion-compatible vertical video jobs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "workflowRunId",
    "contentIdeaId",
    "source",
    "requestedAt",
    "idea",
    "render",
    "assets"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "workflowRunId": {
      "type": "integer",
      "minimum": 1
    },
    "contentIdeaId": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "idea": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic",
        "script",
        "caption",
        "keyword"
      ],
      "properties": {
        "category": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "topic": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "hook": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 140
        },
        "script": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "caption": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2200
        },
        "keyword": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "language": {
          "type": "string",
          "default": "fr"
        },
        "cta": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 140
        },
        "visualStyle": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 240
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openId": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 255
        },
        "nickname": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 255
        }
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "templateId",
        "aspectRatio",
        "width",
        "height",
        "fps",
        "durationSec",
        "qualityProfile"
      ],
      "properties": {
        "templateId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "aspectRatio": {
          "type": "string",
          "const": "9:16"
        },
        "width": {
          "type": "integer",
          "enum": [
            720,
            1080
          ]
        },
        "height": {
          "type": "integer",
          "enum": [
            1280,
            1920
          ]
        },
        "fps": {
          "type": "integer",
          "enum": [
            24,
            25,
            30,
            60
          ]
        },
        "durationSec": {
          "type": "number",
          "minimum": 5,
          "maximum": 120
        },
        "qualityProfile": {
          "type": "string",
          "enum": [
            "draft",
            "standard",
            "high",
            "premium"
          ]
        },
        "captionMode": {
          "type": "string",
          "enum": [
            "none",
            "line",
            "karaoke",
            "word"
          ],
          "default": "line"
        },
        "sceneStrategy": {
          "type": "string",
          "enum": [
            "single-background",
            "timed-scenes",
            "mixed-media"
          ],
          "default": "single-background"
        },
        "safeZones": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "topPx": {
              "type": "integer",
              "minimum": 0
            },
            "rightPx": {
              "type": "integer",
              "minimum": 0
            },
            "bottomPx": {
              "type": "integer",
              "minimum": 0
            },
            "leftPx": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backgroundVideo"
      ],
      "properties": {
        "backgroundVideo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url"
          ],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "provider": {
              "type": [
                "string",
                "null"
              ]
            },
            "license": {
              "type": [
                "string",
                "null"
              ]
            },
            "width": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "height": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "durationSec": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "qualityScore": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            }
          }
        },
        "voiceover": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "provider": {
              "type": [
                "string",
                "null"
              ]
            },
            "voiceId": {
              "type": [
                "string",
                "null"
              ]
            },
            "volume": {
              "type": "number",
              "minimum": 0,
              "maximum": 200,
              "description": "Voice-over volume in percent (0–200). 100 = no change."
            }
          }
        },
        "music": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "volume": {
              "type": "number",
              "minimum": 0,
              "maximum": 200,
              "description": "Music track volume in percent (0–200). 100 = no change."
            }
          }
        },
        "captions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "text",
              "startMs",
              "endMs"
            ],
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "startMs": {
                "type": "integer",
                "minimum": 0
              },
              "endMs": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "overlays": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "title",
                  "subtitle",
                  "cta",
                  "logo",
                  "badge"
                ]
              },
              "text": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "startMs": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "endMs": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              }
            }
          }
        },
        "scenes": {
          "description": "Découpage multi-scènes (contrat 1.1.0). Si présent et non-vide, sceneStrategy=timed-scenes consomme cette liste plutôt que backgroundVideo.",
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "index",
              "durationSec",
              "media"
            ],
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 0
              },
              "durationSec": {
                "type": "number",
                "minimum": 0.5,
                "maximum": 30
              },
              "text": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 240
              },
              "emotion": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 60
              },
              "mediaQuery": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 240
              },
              "cameraMood": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 80
              },
              "overlayPriority": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 40
              },
              "textStyle": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "properties": {
                  "textX": { "type": "number", "minimum": 0, "maximum": 100 },
                  "textY": { "type": "number", "minimum": 0, "maximum": 100 },
                  "textColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
                  "fontFamily": { "type": "string", "maxLength": 80 },
                  "fontSize": { "type": "number", "minimum": 10, "maximum": 120 },
                  "fontWeight": { "type": "integer", "minimum": 100, "maximum": 1000 },
                  "uppercase": { "type": "boolean" },
                  "shadow": { "type": "string", "enum": ["none", "soft", "strong"] }
                }
              },
              "media": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "provider": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "license": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "width": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "minimum": 1
                  },
                  "height": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "minimum": 1
                  },
                  "durationSec": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "minimum": 0
                  },
                  "qualityScore": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 150
        },
        "privacyLevel": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
