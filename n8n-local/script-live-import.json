                  {
                      "parameters":  {
                                         "jsCode":  "const contentIdeaId = Number($json.body?.contentIdeaId || $json.contentIdeaId || 0);\nconst topic = String($json.body?.topic || $json.topic || \u0027\u0027).trim();\nconst category = String($json.body?.category || $json.category || \u0027\u0027).trim();\nconst workflowRunId = Number($json.body?.workflowRunId || $json.workflowRunId || 0);\n\nif (!contentIdeaId || contentIdeaId \u003c= 0) throw new Error(\u0027contentIdeaId invalide\u0027);\nif (!topic) throw new Error(\u0027topic manquant\u0027);\nif (!category) throw new Error(\u0027category manquant\u0027);\nif (!workflowRunId || workflowRunId \u003c= 0) throw new Error(\u0027workflowRunId invalide\u0027);\n\nif (topic.length \u003e 200) throw new Error(\u0027topic trop long (max 200 chars)\u0027);\nif (category.length \u003e 50) throw new Error(\u0027category trop long (max 50 chars)\u0027);\n\nreturn [{ json: { contentIdeaId, topic, category, workflowRunId } }];"
                                     },
                      "id":  "validate-input",
                      "name":  "Validate Input",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -600,
                                       120
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://api.groq.com/openai/v1/chat/completions",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Authorization",
                                                                                         "value":  "={{ \u0027Bearer \u0027 + $env.GROQ_API_KEY }}"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ model: \u0027llama-3.3-70b-versatile\u0027, temperature: 0.6, max_tokens: 500, messages: [ { role: \u0027system\u0027, content: \u0027Tu es un expert en création de contenu viral TikTok. Tu generes des scripts courts, punchant et optimisés pour mobile. Retourne UNIQUEMENT un JSON valide sans markdown.\u0027 }, { role: \u0027user\u0027, content: \u0027Categorie: \u0027 + $json.category + \u0027\\nTopic: \u0027 + $json.topic + \u0027\\n\\nGenere un script TikTok professionnel:\\n- Script: 1-3 phrases courtes et impactantes, francais naturel et conversationnel\\n- Caption: 1-2 phrases accrochantes avec 2-3 hashtags pertinents\\n- Hook: une premiere phrase engageante pour accrocher en 1s\\n- Tone: professionnel mais accessible\\n\\nRetourne ce JSON exactement:\\n{\"script\":\"...\",\"caption\":\"...\",\"hook\":\"...\",\"background_keyword\":\"...\"}\u0027 } ] }) }}",
                                         "options":  {
                                                         "retry":  {
                                                                       "maxRetries":  2,
                                                                       "delayMultiplier":  2,
                                                                       "initialDelay":  1000
                                                                   },
                                                         "timeout":  30000
                                                     }
                                     },
                      "id":  "http-groq-script",
                      "name":  "HTTP: Groq Script Generation",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.4,
                      "position":  [
                                       -320,
                                       120
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const raw = String($json.choices?.[0]?.message?.content || \u0027\u0027).trim();\nconst cleaned = raw.replace(/^```json\\s*/i, \u0027\u0027).replace(/^```/i, \u0027\u0027).replace(/```$/i, \u0027\u0027).trim();\nlet parsed;\ntry { parsed = JSON.parse(cleaned); } catch (error) {\n  throw new Error(\u0027Reponse LLM non parseable: \u0027 + cleaned.slice(0, 200));\n}\n\nif (!parsed.script) throw new Error(\u0027script manquant dans la reponse LLM\u0027);\nif (!parsed.caption) throw new Error(\u0027caption manquant dans la reponse LLM\u0027);\nif (!parsed.hook) throw new Error(\u0027hook manquant dans la reponse LLM\u0027);\nif (!parsed.background_keyword) throw new Error(\u0027background_keyword manquant\u0027);\n\nconst script = String(parsed.script).trim().slice(0, 300);\nconst caption = String(parsed.caption).trim().slice(0, 150);\nconst hook = String(parsed.hook).trim().slice(0, 100);\nconst background_keyword = String(parsed.background_keyword).trim().slice(0, 50);\n\nif (script.length \u003c 10) throw new Error(\u0027script trop court\u0027);\nif (caption.length \u003c 5) throw new Error(\u0027caption trop court\u0027);\nif (hook.length \u003c 5) throw new Error(\u0027hook trop court\u0027);\n\nreturn [{ json: { contentIdeaId: Number($(\u0027Validate Input\u0027).item.json.contentIdeaId || 0), workflowRunId: Number($(\u0027Validate Input\u0027).item.json.workflowRunId || 0), script, caption, hook, background_keyword, topic: $(\u0027Validate Input\u0027).item.json.topic } }];"
                                     },
                      "id":  "parse-and-validate",
                      "name":  "Parse \u0026 Validate Script",
                      "type":  "n8n-nodes-base.code",
