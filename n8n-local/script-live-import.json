                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const baseUrl = String($env.APP_VIDEO_OPS_BACKEND_BASE_URL || \u0027\u0027).replace(/\\/+$/, \u0027\u0027);\nconst callbackSecret = String($env.APP_VIDEO_OPS_WORKFLOW_CALLBACK_SECRET || \u0027\u0027);\nconst contentIdeaId = Number($(\u0027Validate Input\u0027).item.json.contentIdeaId || 0);\nconst workflowRunId = Number($(\u0027Validate Input\u0027).item.json.workflowRunId || 0);\nconst error = $json;\n\nlet errorMessage = \u0027Unknown error\u0027;\nif (typeof error === \u0027string\u0027) errorMessage = error;\nelse if (error.message) errorMessage = error.message;\nelse if (error.error?.message) errorMessage = error.error.message;\n\nif (!baseUrl || !callbackSecret || !workflowRunId) {\n  return [{ json: { status: \u0027FAILED\u0027, message: \u0027Missing config\u0027 } }];\n}\n\nconst body = JSON.stringify({\n  status: \u0027FAILED\u0027,\n  message: \u0027Script generation failed: \u0027 + errorMessage.slice(0, 200),\n  responsePayload: JSON.stringify({ contentIdeaId, error: errorMessage.slice(0, 500) })\n});\n\nconst http = require(\u0027http\u0027);\nconst https = require(\u0027https\u0027);\nconst { URL } = require(\u0027url\u0027);\nconst url = new URL(baseUrl + \u0027/api/video-ops/workflow-runs/\u0027 + workflowRunId + \u0027/complete\u0027);\nconst client = url.protocol === \u0027https:\u0027 ? https : http;\n\nconst response = await new Promise((resolve) =\u003e {\n  let attempts = 0;\n  const maxAttempts = 2;\n\n  const tryRequest = () =\u003e {\n    const req = client.request({\n      protocol: url.protocol,\n      hostname: url.hostname,\n      port: url.port || (url.protocol === \u0027https:\u0027 ? 443 : 80),\n      path: url.pathname + url.search,\n      method: \u0027POST\u0027,\n      headers: {\n        \u0027Content-Type\u0027: \u0027application/json\u0027,\n        \u0027Content-Length\u0027: Buffer.byteLength(body),\n        \u0027X-Video-Ops-Callback-Secret\u0027: callbackSecret,\n        \u0027X-Request-Timestamp\u0027: Date.now().toString()\n      }\n    }, (res) =\u003e {\n      let data = \u0027\u0027;\n      res.on(\u0027data\u0027, (chunk) =\u003e { data += chunk; });\n      res.on(\u0027end\u0027, () =\u003e resolve({ statusCode: res.statusCode || 0, body: data }));\n    });\n\n    req.on(\u0027error\u0027, () =\u003e {\n      attempts++;\n      if (attempts \u003c maxAttempts) {\n        setTimeout(tryRequest, 2000);\n      } else {\n        resolve({ statusCode: 0, body: \u0027Error callback failed\u0027 });\n      }\n    });\n\n    req.setTimeout(10000, () =\u003e {\n      req.destroy();\n      attempts++;\n      if (attempts \u003c maxAttempts) {\n        setTimeout(tryRequest, 2000);\n      } else {\n        resolve({ statusCode: 0, body: \u0027Error callback timeout\u0027 });\n      }\n    });\n\n    req.write(body);\n    req.end();\n  };\n\n  tryRequest();\n});\n\nreturn [{ json: { status: \u0027FAILED\u0027, message: \u0027Error callback sent (best effort)\u0027 } }];"
                                     },
