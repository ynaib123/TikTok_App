                  },
                  {
                      "parameters":  {
                                         "respondWith":  "json",
                                         "responseBody":  "={{ { ok: true, contentIdeaId: $(\u0027Parse \u0026 Validate Script\u0027).item.json.contentIdeaId, workflowRunId: $(\u0027Parse \u0026 Validate Script\u0027).item.json.workflowRunId, status: \u0027script_ready\u0027, script_length: ($(\u0027Parse \u0026 Validate Script\u0027).item.json.script || \u0027\u0027).length } }}",
