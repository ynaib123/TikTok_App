                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ scripts: $json.script, script_status: \u0027done\u0027, script_hook: $json.hook, caption: $json.caption, background_keyword: $json.background_keyword, pipeline_status: \u0027script_ready\u0027, llm_model: \u0027llama-3.3-70b-versatile\u0027 }) }}",
                                         "options":  {
                                                         "retry":  {
                                                                       "maxRetries":  2,
