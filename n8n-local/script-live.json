                      "parameters":  {
                                         "respondWith":  "json",
                                         "responseBody":  "={{ { ok: true, contentIdeaId: $(\u0027Parse JSON\u0027).item.json.contentIdeaId, workflowRunId: $(\u0027Parse JSON\u0027).item.json.workflowRunId, status: \u0027script_ready\u0027 } }}",
