                                         "jsCode":  "const data = $json.body;\nif (!data || !data.accessToken) throw new Error(\u0027accessToken manquant du contexte\u0027);\nif (!data.title) throw new Error(\u0027title manquant du contexte\u0027);\nif (!data.shotstackUrl) throw new Error(\u0027shotstackUrl manquant du contexte\u0027);\nif (!data.selectedPrivacyLevel) throw new Error(\u0027selectedPrivacyLevel manquant du contexte\u0027);\n\nreturn [{ json: { accessToken: data.accessToken, title: String(data.title).trim().slice(0, 150), shotstackUrl: data.shotstackUrl, selectedPrivacyLevel: data.selectedPrivacyLevel, contentIdeaId: $(\u0027Validate Input\u0027).item.json.contentIdeaId } }];"
