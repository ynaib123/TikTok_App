                                         "jsCode":  "const data = $json.body || $json.data;\nif ($json.statusCode \u003e= 400) throw new Error(\u0027TikTok API error: \u0027 + $json.statusCode + \u0027 \u0027 + JSON.stringify(data));\nif (!data.data?.publish_id) throw new Error(\u0027No publish_id returned from TikTok\u0027);\nif (!data.data?.upload_url) throw new Error(\u0027No upload_url returned from TikTok\u0027);\n\nreturn [{ json: { publishId: data.data.publish_id, uploadUrl: data.data.upload_url, contentIdeaId: $(\u0027Validate Init Context\u0027).item.json.contentIdeaId } }];"
