                  {
                      "parameters":  {
                                         "jsCode":  "const baseUrl = String($env.APP_VIDEO_OPS_BACKEND_BASE_URL || \u0027\u0027).replace(/\\/+$/, \u0027\u0027);\nconst callbackSecret = String($env.APP_VIDEO_OPS_WORKFLOW_CALLBACK_SECRET || \u0027\u0027);\nconst workflowRunId = Number($(\u0027Validate Input\u0027).item.json.workflowRunId || 0);\nconst contentIdeaId = Number($json.contentIdeaId || 0);\nconst publishId = $json.publishId || \u0027\u0027;\nconst uploadUrl = $json.uploadUrl || \u0027\u0027;\n\nif (!baseUrl) throw new Error(\u0027APP_VIDEO_OPS_BACKEND_BASE_URL manquante\u0027);\nif (!callbackSecret) throw new Error(\u0027APP_VIDEO_OPS_WORKFLOW_CALLBACK_SECRET manquante\u0027);\nif (!workflowRunId) throw new Error(\u0027workflowRunId manquant\u0027);\n\nconst body = JSON.stringify({\n  status: \u0027SUCCEEDED\u0027,\n  message: \u0027Init publish TikTok termine.\u0027,\n  responsePayload: JSON.stringify({ contentIdeaId, publishId, uploadUrl })\n});\n\nconst http = require(\u0027http\u0027);\nconst https = require(\u0027https\u0027);\nconst { URL } = require(\u0027url\u0027);\nconst url = new URL(baseUrl + \u0027/api/video-ops/workflow-runs/\u0027 + workflowRunId + \u0027/complete\u0027);\nconst client = url.protocol === \u0027https:\u0027 ? https : http;\n\nconst response = await new Promise((resolve, reject) =\u003e {\n  let attempts = 0;\n  const maxAttempts = 3;\n\n  const tryRequest = () =\u003e {\n    const req = client.request({\n      protocol: url.protocol,\n      hostname: url.hostname,\n      port: url.port || (url.protocol === \u0027https:\u0027 ? 443 : 80),\n      path: url.pathname + url.search,\n      method: \u0027POST\u0027,\n      headers: {\n        \u0027Content-Type\u0027: \u0027application/json\u0027,\n        \u0027Content-Length\u0027: Buffer.byteLength(body),\n        \u0027X-Video-Ops-Callback-Secret\u0027: callbackSecret,\n        \u0027X-Request-Timestamp\u0027: Date.now().toString()\n      }\n    }, (res) =\u003e {\n      let data = \u0027\u0027;\n      res.on(\u0027data\u0027, (chunk) =\u003e { data += chunk; });\n      res.on(\u0027end\u0027, () =\u003e resolve({ statusCode: res.statusCode || 0, body: data }));\n    });\n\n    req.on(\u0027error\u0027, (err) =\u003e {\n      attempts++;\n      if (attempts \u003c maxAttempts) {\n        setTimeout(tryRequest, Math.pow(2, attempts) * 1000);\n      } else {\n        reject(err);\n      }\n    });\n\n    req.setTimeout(20000, () =\u003e {\n      req.destroy();\n      attempts++;\n      if (attempts \u003c maxAttempts) {\n        setTimeout(tryRequest, Math.pow(2, attempts) * 1000);\n      } else {\n        reject(new Error(\u0027Callback timeout\u0027));\n      }\n    });\n\n    req.write(body);\n    req.end();\n  };\n\n  tryRequest();\n});\n\nif (response.statusCode \u003c 200 || response.statusCode \u003e= 300) {\n  throw new Error(\u0027Callback failed: \u0027 + response.statusCode + \u0027 \u0027 + response.body);\n}\n\nreturn [{ json: { ok: true, contentIdeaId, publishId, uploadUrl, callbackStatusCode: response.statusCode } }];"
                                     },
