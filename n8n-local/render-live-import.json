                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify((() =\u003e {\n  const selected = $(\u0027Select Media (Scored)\u0027).item.json;\n  const cleanText = (value) =\u003e String(value || \u0027\u0027).normalize(\u0027NFKD\u0027).replace(/[^\\x20-\\x7E]/g, \u0027 \u0027).replace(/\\s+/g, \u0027 \u0027).trim().slice(0, 120);\n  \n  // Text layers from hook + script\n  const textLines = [];\n  if (selected.hook) textLines.push(cleanText(selected.hook));\n  const scriptLines = (selected.script || \u0027\u0027).split(\u0027\\n\u0027).map(l =\u003e cleanText(l)).filter(Boolean);\n  textLines.push(...scriptLines.slice(0, 2));\n  \n  // Professional gradient background colors based on aesthetic\n  const bgColors = {\n    \u0027modern\u0027: { gradient: \u0027#0f1419 to #1a1f2e\u0027, text: \u0027#ffffff\u0027 },\n    \u0027corporate\u0027: { gradient: \u0027#1c2841 to #2d3a4f\u0027, text: \u0027#ffffff\u0027 },\n    \u0027creative\u0027: { gradient: \u0027#2a1635 to #3d1f47\u0027, text: \u0027#ffffff\u0027 },\n    \u0027tech\u0027: { gradient: \u0027#0d1b2a to #1e3a5f\u0027, text: \u0027#00d9ff\u0027 },\n    \u0027lifestyle\u0027: { gradient: \u0027#1a1a1a to #3a3a3a\u0027, text: \u0027#ffffff\u0027 }\n  };\n  const theme = bgColors[\u0027modern\u0027]; // Could be enhanced with aesthetic detection\n  \n  // Text clips with professional styling\n  const titleClips = textLines.filter(Boolean).map((line, index) =\u003e ({\n    asset: {\n      type: \u0027title\u0027,\n      text: line,\n      style: \u0027bold\u0027,\n      fontFamily: \u0027Arial\u0027,\n      fontSize: 48,\n      color: theme.text,\n      background: \u0027rgba(15, 15, 15, 0.65)\u0027,\n      padding: 16,\n      align: \u0027center\u0027,\n      weight: 700\n    },\n    start: index * 3.5,\n    length: 3,\n    position: \u0027center\u0027,\n    opacity: 1\n  }));\n  \n  return {\n    timeline: {\n      background: theme.gradient.split(\u0027 to \u0027)[0],\n      tracks: [\n        {\n          clips: [\n            {\n              asset: {\n                type: \u0027video\u0027,\n                src: selected.background_video_url\n              },\n              start: 0,\n              length: 15,\n              fit: \u0027cover\u0027,\n              opacity: 0.85\n            }\n          ]\n        },\n        ...(titleClips.length ? [{\n          clips: titleClips\n        }] : [])\n      ]\n    },\n    output: {\n      format: \u0027mp4\u0027,\n      aspectRatio: \u00279:16\u0027,\n      resolution: \u0027hd\u0027,\n      quality: \u0027high\u0027,\n      fps: 30,\n      bitrate: \u00276000k\u0027\n    }\n  };\n})()) }}",
