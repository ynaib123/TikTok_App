                  {
                      "parameters":  {
                                         "jsCode":  "const videos = $json.videos || [];\nif (!videos.length) throw new Error(\u0027Aucune video Pexels trouvee\u0027);\n\nconst PEXELS_HOST = \u0027videos.pexels.com\u0027;\nconst PREFERRED_ASPECT = 1.777; // 16:9\nconst TARGET_WIDTH = 1080;\nconst MIN_DURATION = 5; // 5 secondes min\nconst MAX_DURATION = 60; // 60 secondes max\n\nconst scoreVideo = (video, file) =\u003e {\n  const width = Number(file.width || video.width || 0);\n  const height = Number(file.height || video.height || 0);\n  const duration = Number(video.duration || 0);\n  const hostname = new URL(file.link).hostname;\n  \n  let score = 0;\n  \n  // Host preference (Pexels direct = +100)\n  if (hostname === PEXELS_HOST) score += 100;\n  else score += 30;\n  \n  // Portrait format (height \u003e width)\n  if (height \u003e width) score += 50;\n  else return 0; // Reject landscape\n  \n  // Resolution preference (1080x1920 ideal)\n  if (width === 1080 \u0026\u0026 height === 1920) score += 150;\n  else if (width === 720 \u0026\u0026 height === 1280) score += 100;\n  else if (width === 540 \u0026\u0026 height === 960) score += 50;\n  else if (width \u003e 1080) score += 80;\n  else if (width \u003e 540) score += 60;\n  else score += 20;\n  \n  // Duration preference (8-20 secondes = optimal)\n  if (duration \u003e= MIN_DURATION \u0026\u0026 duration \u003c= MAX_DURATION) {\n    const ideal = duration \u003c= 15 ? 150 : duration \u003c= 30 ? 120 : 80;\n    score += ideal;\n  } else return 0; // Reject too short or too long\n  \n  // File type (mp4 is standard)\n  if (file.file_type === \u0027video/mp4\u0027) score += 40;\n  \n  // Diverse content (penalize too common subjects)\n  // This would need backend tracking, skip for now\n  \n  return score;\n};\n\nconst candidates = [];\nfor (const video of videos) {\n  for (const file of video.video_files || []) {\n    if (!file?.link) continue;\n    const score = scoreVideo(video, file);\n    if (score \u003e 0) {\n      candidates.push({\n        link: file.link,\n        width: Number(file.width || video.width || 0),\n        height: Number(file.height || video.height || 0),\n        duration: Number(video.duration || 0),\n        photographer: video.user?.name || \u0027Unknown\u0027,\n        score\n      });\n    }\n  }\n}\n\nif (!candidates.length) throw new Error(\u0027Aucune video portrait de qualite trouvee\u0027);\n\n// Sort by score descending\ncandidates.sort((a, b) =\u003e b.score - a.score);\n\n// Pick top candidate with quality check\nconst selected = candidates[0];\nif (selected.score \u003c 50) throw new Error(\u0027Media quality too low (score: \u0027 + selected.score + \u0027)\u0027);\n\nreturn [{ json: {\n  id: $(\u0027Validate Input\u0027).item.json.contentIdeaId,\n  workflowRunId: $(\u0027Validate Input\u0027).item.json.workflowRunId,\n  topic: $(\u0027Validate Input\u0027).item.json.topic,\n  script: $(\u0027Validate Input\u0027).item.json.script,\n  hook: $(\u0027Validate Input\u0027).item.json.hook,\n  caption: $(\u0027Validate Input\u0027).item.json.caption,\n  aesthetic: $(\u0027Validate Aesthetic\u0027).item.json.aesthetic,\n  background_video_url: selected.link,\n  media_score: selected.score,\n  media_quality: selected.score \u003e 200 ? \u0027premium\u0027 : selected.score \u003e 100 ? \u0027high\u0027 : \u0027standard\u0027,\n  media_duration: selected.duration,\n  media_resolution: selected.width + \u0027x\u0027 + selected.height\n} }];"
