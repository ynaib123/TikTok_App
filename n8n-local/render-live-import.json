                                         "jsCode":  "const contentIdeaId = Number($json.body?.contentIdeaId || $json.contentIdeaId || 0);\nconst topic = String($json.body?.topic || $json.topic || \u0027\u0027).trim();\nconst script = String($json.body?.script || $json.script || \u0027\u0027).trim();\nconst hook = String($json.body?.hook || $json.hook || \u0027\u0027).trim();\nconst caption = String($json.body?.caption || $json.caption || \u0027\u0027).trim();\nconst keyword = String($json.body?.keyword || $json.keyword || topic).trim();\nconst workflowRunId = Number($json.body?.workflowRunId || $json.workflowRunId || 0);\n\nif (!contentIdeaId || contentIdeaId \u003c= 0) throw new Error(\u0027contentIdeaId invalide\u0027);\nif (!script) throw new Error(\u0027script manquant\u0027);\nif (!hook) throw new Error(\u0027hook manquant\u0027);\nif (!workflowRunId || workflowRunId \u003c= 0) throw new Error(\u0027workflowRunId invalide\u0027);\n\nif (script.length \u003e 500) throw new Error(\u0027script trop long\u0027);\nif (hook.length \u003e 100) throw new Error(\u0027hook trop long\u0027);\n\nreturn [{ json: { contentIdeaId, topic, script, hook, caption, keyword, workflowRunId } }];"
