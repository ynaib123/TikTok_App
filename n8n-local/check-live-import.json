                      "id":  "shotstack-status",
                      "name":  "HTTP: Get Shotstack Status",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.4,
                      "position":  [
                                       360,
                                       100
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const statusData = $json.body || $json;\nif (!statusData || !statusData.response) throw new Error(\u0027Invalid Shotstack response\u0027);\n\nconst status = String(statusData.response?.status || \u0027\u0027).toLowerCase();\nconst ideaId = $(\u0027Validate Render State\u0027).item.json.ideaId;\nconst validStatuses = [\u0027queued\u0027, \u0027rendering\u0027, \u0027preparing\u0027, \u0027done\u0027, \u0027failed\u0027, \u0027timeout\u0027];\n\nif (!validStatuses.includes(status)) {\n  throw new Error(\u0027Invalid Shotstack status: \u0027 + status);\n}\n\nif (status === \u0027done\u0027) {\n  if (!statusData.response?.url) throw new Error(\u0027No video URL in completed Shotstack response\u0027);\n  return [{ json: {\n    noUpdate: false,\n    ideaId,\n    patch: {\n      shotstack_status: \u0027done\u0027,\n      shotstack_url: statusData.response.url,\n      final_video_status: \u0027ready\u0027,\n      pipeline_status: \u0027render_ready\u0027\n    },\n    callbackStatus: \u0027SUCCEEDED\u0027,\n    callbackMessage: \u0027Render Shotstack termine.\u0027\n  } }];\n}\n\nif (status === \u0027failed\u0027 || status === \u0027timeout\u0027) {\n  return [{ json: {\n    noUpdate: false,\n    ideaId,\n    patch: {\n      shotstack_status: status,\n      final_video_status: \u0027failed\u0027,\n      pipeline_status: \u0027failed\u0027\n    },\n    callbackStatus: \u0027FAILED\u0027,\n    callbackMessage: \u0027Render Shotstack en echec (\u0027 + status + \u0027).\u0027\n  } }];\n}\n\nreturn [{ json: {\n  noUpdate: true,\n  ideaId,\n  shotstackStatus: status,\n  message: \u0027Render Shotstack toujours en cours.\u0027\n} }];"
                                     },
