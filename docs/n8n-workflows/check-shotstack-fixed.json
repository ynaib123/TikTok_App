{
  "name": "check-shotstack-fixed",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1
            }
          ]
        }
      },
      "id": "schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [-840, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ String($env.APP_VIDEO_OPS_SUPABASE_URL || '').replace(/\\/+$/, '') + '/rest/v1/content_ideas?shotstack_render_id=not.is.null&final_video_status=eq.processing' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.APP_VIDEO_OPS_SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.APP_VIDEO_OPS_SUPABASE_SERVICE_ROLE_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "get-renders",
      "name": "HTTP Request Get Pending Renders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-600, 100]
    },
    {
      "parameters": {
        "jsCode": "return $input.all().filter(item => ['queued', 'rendering', 'preparing'].includes(String(item.json.shotstack_status || '').toLowerCase()));"
      },
      "id": "filter-status",
      "name": "Filter Valid Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-360, 100]
    },
    {
      "parameters": {
        "url": "={{ 'https://api.shotstack.io/v1/render/' + String($json.shotstack_render_id || '').trim() }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.SHOTSTACK_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "shotstack-status",
      "name": "HTTP Request Shotstack Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-120, 100]
    },
    {
      "parameters": {
        "jsCode": "const status = String($json.response?.status || '').toLowerCase();\nconst base = $('Filter Valid Status').item.json;\nif (status === 'done') {\n  return [{ json: { id: base.id, shotstack_status: 'done', shotstack_url: $json.response?.url || '', final_video_status: 'ready', pipeline_status: 'render_ready' } }];\n}\nif (status === 'failed') {\n  return [{ json: { id: base.id, shotstack_status: 'failed', final_video_status: 'failed', pipeline_status: 'failed' } }];\n}\nreturn [];"
      },
      "id": "map-update",
      "name": "Build Update Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [120, 100]
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "content_ideas",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
      "parameters": {
        "method": "PATCH",
        "url": "={{ String($env.APP_VIDEO_OPS_SUPABASE_URL || '').replace(/\\/+$/, '') + '/rest/v1/content_ideas?id=eq.' + $json.id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.APP_VIDEO_OPS_SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.APP_VIDEO_OPS_SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "shotstack_status",
              "value": "={{ $json.shotstack_status }}"
            },
            {
              "name": "shotstack_url",
              "value": "={{ $json.shotstack_url || '' }}"
            },
            {
              "name": "final_video_status",
              "value": "={{ $json.final_video_status }}"
            },
            {
              "name": "pipeline_status",
              "value": "={{ $json.pipeline_status }}"
            }
          ]
        },
        "options": {}
      },
      "id": "update-row",
      "name": "HTTP Request Update Row",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [360, 100]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[{ "node": "HTTP Request Get Pending Renders", "type": "main", "index": 0 }]]
    },
    "HTTP Request Get Pending Renders": {
      "main": [[{ "node": "Filter Valid Status", "type": "main", "index": 0 }]]
    },
    "Filter Valid Status": {
      "main": [[{ "node": "HTTP Request Shotstack Status", "type": "main", "index": 0 }]]
    },
    "HTTP Request Shotstack Status": {
      "main": [[{ "node": "Build Update Payload", "type": "main", "index": 0 }]]
    },
    "Build Update Payload": {
      "main": [[{ "node": "HTTP Request Update Row", "type": "main", "index": 0 }]]
    }
  },
  "pinData": {},
  "meta": {
    "templateCredsSetupCompleted": true
  }
}
